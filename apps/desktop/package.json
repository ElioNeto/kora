{
  "name": "kora-editor",
  "version": "0.3.0",
  "description": "Kora Game Engine Editor - Desktop Application (Electron)",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux"
  },
  "keywords": [
    "game-engine",
    "2d",
    "android",
    "editor",
    "electron",
    "kscript"
  ],
  "author": "Kora Engine Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/koraengine/kora"
  },
  "homepage": "https://github.com/koraengine/kora",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.koraengine.editor",
    "productName": "Kora Editor",
    "copyright": "Copyright © 2024 Kora Engine",
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*"
    ],
    "extraResources": [
      {
        "from": "../editor",
        "to": "editor",
        "filter": ["**/*"]
      },
      {
        "from": "../../compiler/bin",
        "to": "compiler",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "assets/icon.png",
      "category": "Game",
      "desktop": {
        "Name": "Kora Editor",
        "Comment": "2D Game Engine for Android",
        "Categories": "Game;Development;"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "koraengine",
      "repo": "desktop"
    }
  }
}
