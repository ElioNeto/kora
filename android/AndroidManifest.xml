<?xml version="1.0" encoding="utf-8"?>
<!--
  Kora Engine — Android Manifest
  Edit package, versionCode and versionName for each release.
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.koragame"
    android:versionCode="1"
    android:versionName="1.0">

    <uses-sdk
        android:minSdkVersion="21"
        android:targetSdkVersion="34" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- OpenGL ES 3.0 requirement (Ebitengine) -->
    <uses-feature
        android:glEsVersion="0x00030000"
        android:required="true" />

    <!-- Touch screen -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="true" />

    <application
        android:label="Kora Game"
        android:icon="@mipmap/ic_launcher"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen"
        android:hardwareAccelerated="true"
        android:allowBackup="false">

        <activity
            android:name="org.golang.app.GoNativeActivity"
            android:label="Kora Game"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout">

            <meta-data
                android:name="android.app.lib_name"
                android:value="koragame" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
