{
  "model": "claude-opus-4-5",
  "context": {
    "includeGitHistory": true,
    "maxContextFiles": 30,
    "alwaysInclude": [
      "CLAUDE.md",
      "go.mod",
      ".claude/memory.json"
    ]
  },
  "behavior": {
    "autoApprove": false,
    "confirmDestructive": true,
    "verboseErrors": true,
    "formatOnSave": true
  },
  "tools": {
    "shell": {
      "allowedCommands": [
        "go build",
        "go test",
        "go vet",
        "go run",
        "go mod tidy",
        "make",
        "bash build.sh"
      ],
      "blockedCommands": [
        "rm -rf",
        "git push --force"
      ]
    }
  },
  "ignoreFile": ".claudeignore",
  "projectType": "go-game-engine",
  "language": "pt-BR"
}
